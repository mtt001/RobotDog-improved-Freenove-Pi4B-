# - 2026-02-26 10:04 v1.0 - Added LINE Messaging API env template for channel token and target recipient id.

# Required: LINE Messaging API channel access token (long-lived or short-lived)
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN

# Required for push mode: userId/groupId/roomId from LINE webhook events
LINE_TO=YOUR_LINE_USER_OR_GROUP_ID
